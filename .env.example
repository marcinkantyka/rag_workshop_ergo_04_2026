# Copy this file to .env and fill in your values

# Required: Netlight LiteLLM proxy credentials
# You will receive these from the workshop organisers
NETLIGHT_API_KEY=sk-...
NETLIGHT_BASE_URL=https://llm.netlight.ai/

# Optional: ChromaDB persistence path (default: ./chroma_db)
# CHROMA_PERSIST_DIR=./chroma_db

# Optional: data directory (default: ./data)
# DATA_DIR=./data
